# ============================================================
# .env.example — ANTIGRAVITI Trading Bot
# Amaç : Gerçek API key'lerinin şablonu. Bu dosyayı kopyalayıp
#         ".env" olarak kaydet ve kendi key'lerini gir.
# Tarih: 2026-06-03
#
# KULLANIM:
#   Windows: copy .env.example .env
#   Linux  : cp .env.example .env
#
# ⚠️  UYARI: Asla gerçek key'lerini bu dosyaya yazma!
#             Bu dosya versiyon kontrolüne girer, .env GİRMEZ.
# ============================================================

# --- Binance API Bilgileri ---
# Binance'tan API anahtarlarını almak için:
# https://www.binance.com/tr/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# --- Ortam Modu ---
# "paper"  → Gerçek para yok, simülasyon modu (BAŞLANGIÇ İÇİN)
# "live"   → Gerçek para, SADECE test sonrası kullan
TRADING_MODE=paper

# --- Telegram Uyarı Botu (Faz 3'te etkinleştirilecek) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Log Seviyesi ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# --- Gemini AI API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter API ---
# OpenRouter üzerinden ücretsiz API kullanımı için:
# https://openrouter.ai/ keys sayfasından anahtar oluşturup buraya yapıştırın.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter modeli (varsayılan: google/gemma-4-31b-it:free)
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Alış/satış sinyallerinin açılmadan önce AI tarafından doğrulanıp filtrelenmesi (true/false)
USE_AI_SIGNAL_VERIFICATION=true
